{
  "name": "octane-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20.0.0", "pnpm": ">=9.0.0" },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "meta:zoho-crm": "tsx metadataScripts/zohoCrmAnalyzer.ts",
    "meta:zoho-desk": "tsx metadataScripts/zohoDeskAnalyzer.ts",
    "meta:zoho-people": "tsx metadataScripts/zohoPeopleAnalyzer.ts",
    "meta:dwh": "tsx metadataScripts/dwhAnalyzer.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "openai": "^4.65.0",
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.4",
    "pg": "^8.13.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.3",
    "jose": "^5.9.3",
    "bcryptjs": "^2.4.3",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "@paralleldrive/cuid2": "^2.2.2",
    "dotenv": "^16.4.5",
    "p-retry": "^6.2.0",
    "p-queue": "^8.0.1",
    "tiktoken": "^1.0.17"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/pg": "^8.11.10",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.6.2",
    "tsx": "^4.19.1",
    "vitest": "^2.1.1",
    "@vitest/coverage-v8": "^2.1.1",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.24.2",
    "eslint": "^8.57.1",
    "@typescript-eslint/parser": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "prettier": "^3.3.3"
  }
}
