{
  "name": "octane-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:widget": "corepack pnpm -C apps/mytrion-crm install --frozen-lockfile && corepack pnpm -C apps/mytrion-crm build",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "seed:scope-risks": "tsx scripts/seed-scope-risks.ts",
    "meta:zoho-crm": "tsx metadataScripts/zohoCrmAnalyzer.ts",
    "meta:zoho-desk": "tsx metadataScripts/zohoDeskAnalyzer.ts",
    "meta:zoho-people": "tsx metadataScripts/zohoPeopleAnalyzer.ts",
    "meta:dwh": "tsx metadataScripts/dwhAnalyzer.ts",
    "zoho:smoke": "tsx scripts/zoho-smoke.ts",
    "zoho:mcp-probe": "tsx scripts/zoho-mcp-probe.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/s3-request-presigner": "^3.1078.0",
    "@composio/core": "^0.13.1",
    "@composio/langchain": "^0.10.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@langchain/openai": "^1.5.3",
    "@paralleldrive/cuid2": "^2.2.2",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^7.0.0",
    "csv-stringify": "^6.8.0",
    "deepagents": "1.10.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.0",
    "jose": "^5.9.3",
    "langchain": "^1.5.2",
    "mammoth": "^1.12.0",
    "openai": "^4.65.0",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.13.0",
    "pg-boss": "^12.24.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "postgres": "^3.4.4",
    "soap": "^1.1.0",
    "unpdf": "^1.6.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.5",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitest/coverage-v8": "^2.1.1",
    "drizzle-kit": "^0.24.2",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
