# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# Project data (runtime)
data/

# Env
.env
.env.local

# Project-specific prompt (not shipped with open-source hamroh)
prompts/project.md

# Local plugin config — operator copies plugins.json.example on setup,
# then customises. Not tracked so different deployments don't fight
# over the file.
plugins.json

# Local access policy — operator copies access.json.example on setup,
# then customises (DM policy, allowed users/chats). Lives at repo root
# alongside plugins.json so both operator-edited config files sit
# together; not tracked so deployments don't fight over the file.
access.json

# Local custom reminders — operator copies default-reminders.json.example on
# setup, then customises. Kept out of the open-source framework repo; an agent
# instance repo tracks its own copy and bind-mounts it in.
default-reminders.json

# Throwaway probe skill created/removed by the e2e suite; never committed
skills/e2e-*/

# Editors
.vscode/
.idea/
.DS_Store
