# LOCAL DEV ONLY. Inside Zoho CRM the widget ignores these and reads the backend URL + key from the
# org variables MYTRION_OPS_API_URL / MYTRION_OPS_API_KEY (see web/README.md). These must never ship
# in the bundle — they are gated behind import.meta.env.DEV so a production build can't inline them.
#
# Point at your local backend, or at production to test against it:
#   VITE_API_URL=https://octane-ops-ai.onrender.com   (production)
VITE_API_URL=http://localhost:3001
VITE_API_KEY=
