# LOCAL DEV ONLY. In production the app is served same-origin with the API and signs workers in via
# Zoho OAuth (Bearer session) — no API key ships in the bundle. These vars are gated behind
# import.meta.env.DEV so a production build can't inline them.
#
# Point at your local backend, or at production to test against it:
#   VITE_API_URL=https://octane-ops-ai.onrender.com   (production)
VITE_API_URL=http://localhost:3001

# Dev API key — used ONLY as a fallback before a Zoho session exists (or with VITE_DEV_MOCK_AUTH).
# Once a worker signs in via Zoho, the app sends the session Bearer token instead.
VITE_API_KEY=

# Set to 1 to bypass Zoho sign-in in dev with a mock admin (transport then uses VITE_API_KEY).
# Leave unset to exercise the real Zoho OAuth login gate locally (redirect URI: http://localhost:5173).
VITE_DEV_MOCK_AUTH=
