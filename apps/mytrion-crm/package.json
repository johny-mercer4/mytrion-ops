{
  "name": "octane-assistant-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mytrion external app (React + TS). Department 'Mytrions' routed by /m/:mytrion; user identity arrives as URL values from a thin Zoho CRM shim (no SDK). Same-origin with the Mytrion Ops backend.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@atlaskit/icon": "36.2.0",
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9",
    "react-router-dom": "^6.26.2",
    "rehype-sanitize": "^6",
    "remark-gfm": "^4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^24",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1"
  }
}
