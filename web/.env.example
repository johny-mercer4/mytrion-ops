# Mytrion Ops backend the widget calls. In a real Zoho widget the call goes through a Zoho
# Connection (key injected server-side); these are for LOCAL dev only and must never ship in the bundle.
VITE_API_URL=http://localhost:3001
# DEV ONLY — never bundle the real API key into a deployed widget (use a Zoho Connection instead).
VITE_API_KEY=
