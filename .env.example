# --- Server ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000
# Allowed origin suffixes (comma-separated). Zoho widgets run on per-instance subdomains
# of zappsusercontent.com, so that whole suffix is allowed (reflected, not "*").
CORS_ORIGIN_SUFFIXES=zappsusercontent.com

# --- Database: Mytrion OPS external Postgres (sessions, logging, knowledge) ---
# The only app DB — no local DB. Required at runtime (the app fails fast if unset).
MYTRION_OPS_DATABASE_URL=
DATABASE_POOL_MAX=10

# --- Data Warehouse (separate read Postgres; tool + metadata target) ---
DWH_DATABASE_URL=

# --- OpenAI ---
OPENAI_API_KEY=
# Model IDs by role: FOUR_O_MINI = default chat, FIVE_O_MINI = reasoning, EMBEDDING_SMALL = vectors.
OPEN_AI_FOUR_O_MINI=gpt-4o-mini-2024-07-18
OPEN_AI_FIVE_O_MINI=gpt-5.4-mini-2026-03-17
OPEN_AI_EMBEDDING_SMALL=text-embedding-3-small
OPENAI_TIMEOUT_MS=60000              # SDK deadline for every raw OpenAI/Groq call
LLM_MAX_OUTPUT_TOKENS=4096           # output cap for chat-pipeline completions
EMBED_BATCH_SIZE=128                 # max inputs per embeddings.create request

# --- Groq (fast/cheap worker via OpenAI-compatible API; off unless FF_GROQ_ENABLED=1) ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_WORKER=openai/gpt-oss-120b

# --- Auth ---
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PASSWORD_PEPPER=

# --- Encryption (for vendor credentials at rest) ---
ENCRYPTION_KEY=                  # 32 bytes base64

# --- Zoho: shared OAuth app (one self-client app across CRM/Desk/People/Projects) ---
# Set ZOHO_ACCOUNTS_DOMAIN to your data center: .com | .eu | .in | .com.au | .jp | .ca
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Optional shared refresh token; fallback when a service-specific token is unset.
ZOHO_REFRESH_TOKEN=

# *_API_DOMAIN / *_BASE_URL are the FULL versioned API roots; code appends the resource path.

# --- Zoho CRM ---
ZOHO_CRM_CLIENT_ID=
ZOHO_CRM_CLIENT_SECRET=
ZOHO_CRM_REFRESH_TOKEN=
ZOHO_CRM_API_DOMAIN=https://www.zohoapis.com/crm/v8

# --- Zoho Desk ---
ZOHO_DESK_REFRESH_TOKEN=
ZOHO_DESK_BASE_URL=https://desk.zoho.com/api/v1
ZOHO_DESK_ORG_ID=

# --- Zoho People ---
ZOHO_PEOPLE_REFRESH_TOKEN=
ZOHO_PEOPLE_BASE_URL=https://people.zoho.com/api

# --- Zoho Projects ---
ZOHO_PROJECTS_REFRESH_TOKEN=
ZOHO_PROJECTS_BASE_URL=https://projectsapi.zoho.com/api/v3

# --- Zoho MCP (feasibility spike; see `pnpm zoho:mcp-probe`) ---
# Per-server URL generated in the Zoho MCP console (embeds a secret API key → treat as a password).
ZOHO_MCP_URL=
# Optional: a separate bearer token, only if the console issues one alongside the URL.
ZOHO_MCP_AUTH=

# --- Department RBAC ---
# Profile/role values (CSV) that grant UNLIMITED access (all departments' RAG + all tools) —
# the Developers/Managers/Admins. Matched as a case-insensitive substring against profile AND role.
# Set precise values if a marker like "manager" would over-match a title (e.g. "Account Manager").
ADMIN_PROFILE_MARKERS=administrator,manager,developer

# --- Vendor: Octane internal API (placeholder) ---
OCTANE_INTERNAL_API_URL=
OCTANE_INTERNAL_API_KEY=

# --- Inbound server API key (callers present this to reach this engine) ---
API_KEY=

# --- CMP (our custom Node server; login/password auth, prod + sandbox) ---
CMP_ENV=sandbox            # which environment the CMP wrapper authenticates against
CMP_PRODUCTION_URL=
CMP_PRODUCTION_LOGIN=
CMP_PRODUCTION_PASSWORD=
CMP_SANDBOX_URL=
CMP_SANDBOX_LOGIN=
CMP_SANDBOX_PASSWORD=

# --- EFS (CardManagement SOAP/WSDL) ---
EFS_WSDL_URL=
EFS_GROUP_WSDL_URL=        # CarrierGroupWS WSDL; derived from EFS_WSDL_URL when blank
EFS_LOGIN=
EFS_PASSWORD=
EFS_PARENT=PARENT

# --- Server CRM (outbound integration) ---
SERVER_CRM_URL=
SERVER_CRM_KEY=

# --- File storage: Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Leave blank to derive https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Optional public/custom-domain base for serving uploaded files
R2_PUBLIC_BASE_URL=
R2_REGION=auto

# --- Browser automation: Browserbase ---
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_BASE_URL=https://api.browserbase.com

# --- Feature flags ---
FF_PARTNER_AUDIENCE_ENABLED=1
FF_KNOWLEDGE_INGEST_ENABLED=1
FF_RAG_ENABLED=1
FF_GROQ_ENABLED=0
# Expose Zoho MCP tools to the chat agent (needs ZOHO_MCP_URL). Read tools only unless …_WRITES=1.
FF_ZOHO_MCP_ENABLED=0
FF_ZOHO_MCP_WRITES=0
FF_AUDIT_LOG_ENABLED=1

# ============================================================
# Agentic Core v2 (2026-07-02) — orchestrator + 10 dept agents
# ============================================================

# --- Multi-agent orchestrator (POST /v1/agent) ---
FF_ORCHESTRATOR_ENABLED=0            # gates /v1/agent (+ legacy alias FF_DEEP_AGENTS_ENABLED)
FF_AGENT_CHECKPOINTS=0               # durable LangGraph threads (schema 'langgraph', setup via migrate)
ORCHESTRATOR_MODEL=                  # '' -> DEEP_AGENTS_MODEL -> default chat model
AGENT_CHILD_MODEL=                   # default child-agent model ('' -> default chat model)
AGENT_MAX_CHILD_ITERATIONS=8
AGENT_TOOL_OUTPUT_MAX_CHARS=8000
AGENT_MAX_TOOL_CALLS=20              # per-run budget guards
AGENT_MAX_COST_USD=0.50
AGENT_MAX_WALL_MS=120000
AGENT_MODEL_TIMEOUT_MS=90000         # per-call deadline for agent-path ChatOpenAI requests
AGENT_MAX_OUTPUT_TOKENS=4096         # output cap for agent-path model calls
OUTBOUND_HTTP_TIMEOUT_MS=30000       # deadline for outbound integration HTTP (serverCrm/Zoho)
ACT_AS_DIRECTORY_TTL_MS=300000       # cache TTL for the CRM users directory verifying act-as targets
AGENT_CHECKPOINT_TTL_DAYS=30
FF_CUSTOMER_SCOPE_STRICT=1           # DEFAULT ON: customer callers locked to their company tag; 0 = temporary legacy rollback
FF_WORKER_DEPT_STRICT=0              # 1 = bound verified non-admin worker departments by their Zoho profile (validate mapping first)
#LANGSMITH_TRACING=true              # optional tracing (staging only — traces contain content)
#LANGSMITH_API_KEY=

# --- Background jobs: pg-boss (own 'pgboss' schema on the app DB) ---
FF_JOBS_ENABLED=0
JOBS_WORKER_MODE=inline              # inline | send-only (dedicated dist/worker.js) | off
PGBOSS_SCHEMA=pgboss
JOBS_CONCURRENCY=2
JOBS_CRON_TZ=America/Chicago

# --- Agentic RAG ---
FF_RAG_HYBRID=0                      # vector + full-text RRF (requires content_tsv migration)
FF_AGENTIC_RAG=0                     # multi-query loop + [Sn] citations
FF_RAG_RERANK=0
RAG_PLANNER_MODEL=
RAG_MAX_HOPS=2
RAG_MULTIQUERY_MAX=3
RAG_RRF_K=60
RAG_CANDIDATES_PER_LEG=30
RAG_SUFFICIENT_SCORE=0.032
STALE_DOC_DAYS=180                   # unverified docs older than this are demoted + flagged

# --- Files: MinIO / any S3-compatible store (R2 = endpoint+region swap) ---
FF_FILES_ENABLED=0
S3_ENDPOINT=                         # e.g. http://localhost:9000 (docker minio) / https://minio.yourhost
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=octane-files
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=1                # MinIO=1; R2=0
S3_PRESIGN_TTL_SECONDS=900
FILE_MAX_SIZE_MB=25
PARSE_MAX_BYTES=10485760

# --- Browser automation via Composio toolkits ---
FF_BROWSER_ENABLED=0
FF_BROWSER_WRITES=0                  # interactive navigate/click/fill actions
COMPOSIO_BROWSER_TOOLKITS=FIRECRAWL  # verify interactive-browser slug in the Composio dashboard
BROWSER_ALLOWED_DOMAINS=             # CSV hostname suffixes; EMPTY = deny all navigation (fail closed)
COMPOSIO_RATE_PER_MIN=30

# --- Write approvals + agent memory ---
FF_WRITE_APPROVALS=0                 # agent-proposed writes park at /v1/approvals (24h TTL)
FF_AGENT_MEMORY=0                    # distill + recall long-term agent memory
AGENT_MEMORY_HALFLIFE_DAYS=30
AGENT_MEMORY_MAX_PER_KEY=500
