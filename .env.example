# --- Server ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000

# --- Database (app's own Postgres: sessions, logging, knowledge) ---
DATABASE_URL=postgres://octane:octane@localhost:5432/octane_assistant
DATABASE_POOL_MAX=10

# --- Data Warehouse (separate read Postgres; tool + metadata target) ---
DWH_DATABASE_URL=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_REASONING_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Auth ---
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PASSWORD_PEPPER=

# --- Encryption (for vendor credentials at rest) ---
ENCRYPTION_KEY=                  # 32 bytes base64

# --- Zoho: shared OAuth app (one self-client app across CRM/Desk/People/Projects) ---
# Set ZOHO_ACCOUNTS_DOMAIN to your data center: .com | .eu | .in | .com.au | .jp | .ca
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Optional shared refresh token; fallback when a service-specific token is unset.
ZOHO_REFRESH_TOKEN=

# --- Zoho CRM ---
ZOHO_CRM_CLIENT_ID=
ZOHO_CRM_CLIENT_SECRET=
ZOHO_CRM_REFRESH_TOKEN=
ZOHO_CRM_API_DOMAIN=https://www.zohoapis.com

# --- Zoho Desk ---
ZOHO_DESK_REFRESH_TOKEN=
ZOHO_DESK_BASE_URL=https://desk.zoho.com
ZOHO_DESK_ORG_ID=

# --- Zoho People ---
ZOHO_PEOPLE_REFRESH_TOKEN=
ZOHO_PEOPLE_BASE_URL=https://people.zoho.com

# --- Zoho Projects ---
ZOHO_PROJECTS_REFRESH_TOKEN=
ZOHO_PROJECTS_BASE_URL=https://projectsapi.zoho.com

# --- Vendor: Octane internal API (placeholder) ---
OCTANE_INTERNAL_API_URL=
OCTANE_INTERNAL_API_KEY=

# --- Feature flags ---
FF_PARTNER_AUDIENCE_ENABLED=1
FF_KNOWLEDGE_INGEST_ENABLED=1
FF_AUDIT_LOG_ENABLED=1
